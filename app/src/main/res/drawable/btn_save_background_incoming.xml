<?xml version="1.0" encoding="utf-8"?>
<!-- Save this as: app/src/main/res/drawable/btn_save_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color (semi-transparent white for outgoing, gray for incoming) -->
    <solid android:color="#2F6DFF" />

    <!-- Border/Frame -->
    <stroke
        android:width="1dp"
        android:color="#FFFFFF" />

    <!-- Rounded corners -->
    <corners android:radius="5dp" />

    <!-- Padding inside button -->
    <padding
        android:left="4dp"
        android:right="4dp"
        android:top="2dp"
        android:bottom="2dp" />
</shape>