<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/qrPreviewView"
        android:layout_width="@dimen/width_0"
        android:layout_height="@dimen/height_0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/qrInstructionText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/qrInstructionText"
        android:layout_width="@dimen/width_0"
        android:layout_height="wrap_content"
        android:text="@string/point_camera_at_qr_code_on_pc_screen"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/size_18"
        android:gravity="center"
        android:padding="@dimen/padding_20"
        android:background="#80000000"
        app:layout_constraintBottom_toTopOf="@id/qrBackButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/qrBackButton"
        android:layout_width="@dimen/width_0"
        android:layout_height="wrap_content"
        android:text="@string/back_qr"
        android:textSize="@dimen/size_18"
        android:layout_margin="@dimen/margin_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--  QR Code frame overlay  -->
    <View
        android:layout_width="@dimen/width_250"
        android:layout_height="@dimen/height_250"
        android:background="@android:color/transparent"
        android:layout_gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>